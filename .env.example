# =============================================
# PluViewAPI - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores

# ---------------------------------------------
# Database Configuration (PostgreSQL)
# ---------------------------------------------
# URL de conexão do Prisma (via connection pooler)
DATABASE_URL=""

# URL direta para migrations (sem pooler)
DIRECT_URL=""

# ---------------------------------------------
# Docker Compose - PostgreSQL (opcional)
# ---------------------------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# ---------------------------------------------
# Application
# ---------------------------------------------
PORT=
NODE_ENV=
