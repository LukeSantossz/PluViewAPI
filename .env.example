# =============================================
# PluViewAPI - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores

# ---------------------------------------------
# Database Configuration (PostgreSQL)
# ---------------------------------------------
# URL de conexão do Prisma (via connection pooler)
DATABASE_URL="postgresql://plueview:plueview123@localhost:5432/plueview?schema=public"

# URL direta para migrations (sem pooler)
DIRECT_URL="postgresql://plueview:plueview123@localhost:5432/plueview?schema=public"

# ---------------------------------------------
# Docker Compose - PostgreSQL (opcional)
# ---------------------------------------------
POSTGRES_USER=plueview
POSTGRES_PASSWORD=plueview123
POSTGRES_DB=plueview
POSTGRES_PORT=5432

# ---------------------------------------------
# Application
# ---------------------------------------------
PORT=3000
NODE_ENV=development
